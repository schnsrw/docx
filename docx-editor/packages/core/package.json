    "./layout-bridge": {
      "types": "./dist/layout-bridge/index.d.ts",
      "import": "./dist/layout-bridge/index.mjs",
      "require": "./dist/layout-bridge/index.js"
    },
    "./plugin-api": {
      "types": "./dist/plugin-api/index.d.ts",
      "import": "./dist/plugin-api/index.mjs",
      "require": "./dist/plugin-api/index.js"
