        "./dist/prosemirror/extensions/index.d.ts"
      ],
      "prosemirror/conversion": [
        "./dist/prosemirror/conversion/index.d.ts"
      ],
      "prosemirror/commands": [
        "./dist/prosemirror/commands/index.d.ts"
      ],
      "prosemirror/plugins": [
        "./dist/prosemirror/plugins/index.d.ts"
      ],
      "docx": [
        "./dist/docx/index.d.ts"
      ],
      "docx/serializer": [
        "./dist/docx/serializer/index.d.ts"
      ],
      "agent": [
        "./dist/agent/index.d.ts"
      ],
      "layout-engine": [
        "./dist/layout-engine/index.d.ts"
      ],
      "layout-painter": [
        "./dist/layout-painter/index.d.ts"
      ],
      "layout-bridge": [
        "./dist/layout-bridge/index.d.ts"
      ],
      "plugin-api": [
        "./dist/plugin-api/index.d.ts"
      ],
      "types/document": [
        "./dist/types/document.d.ts"
      ],
      "types/content": [
        "./dist/types/content.d.ts"
      ],
      "types/agentApi": [
        "./dist/types/agentApi.d.ts"
      ],
      "utils": [
        "./dist/utils/index.d.ts"
      ]
    }
  },
  "bin": {
    "docx-editor-mcp": "./dist/mcp-cli.mjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && node scripts/copy-assets.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "docxtemplater": "^3.50.0",
    "emf-converter": "^1.1.6",
    "jszip": "^3.10.1",
    "pizzip": "^3.1.7",
    "xml-js": "^1.6.11"
  },
  "peerDependencies": {
    "prosemirror-commands": "^1.5.2",
    "prosemirror-dropcursor": "^1.8.2",
    "prosemirror-history": "^1.4.0",
