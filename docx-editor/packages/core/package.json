{
  "name": "@eigenpal/docx-core",
  "version": "0.0.28",
  "private": true,
  "sideEffects": false,
  "description": "Framework-agnostic core for DOCX parsing, editing, and rendering",
  "main": "./dist/core.js",
  "module": "./dist/core.mjs",
  "types": "./dist/core.d.ts",
  "exports": {
    ".": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.mjs",
      "require": "./dist/core.js"
    },
    "./headless": {
      "types": "./dist/headless.d.ts",
      "import": "./dist/headless.mjs",
      "require": "./dist/headless.js"
    },
    "./core-plugins": {
      "types": "./dist/core-plugins.d.ts",
      "import": "./dist/core-plugins.mjs",
      "require": "./dist/core-plugins.js"
    },
    "./mcp": {
      "types": "./dist/mcp.d.ts",
      "import": "./dist/mcp.mjs",
      "require": "./dist/mcp.js"
    },
    "./prosemirror": {
      "types": "./dist/prosemirror/index.d.ts",
      "import": "./dist/prosemirror/index.mjs",
      "require": "./dist/prosemirror/index.js"
    },
    "./prosemirror/extensions": {
      "types": "./dist/prosemirror/extensions/index.d.ts",
      "import": "./dist/prosemirror/extensions/index.mjs",
      "require": "./dist/prosemirror/extensions/index.js"
    },
    "./prosemirror/conversion": {
      "types": "./dist/prosemirror/conversion/index.d.ts",
      "import": "./dist/prosemirror/conversion/index.mjs",
      "require": "./dist/prosemirror/conversion/index.js"
    },
    "./prosemirror/commands": {
      "types": "./dist/prosemirror/commands/index.d.ts",
      "import": "./dist/prosemirror/commands/index.mjs",
      "require": "./dist/prosemirror/commands/index.js"
    },
    "./prosemirror/plugins": {
      "types": "./dist/prosemirror/plugins/index.d.ts",
      "import": "./dist/prosemirror/plugins/index.mjs",
      "require": "./dist/prosemirror/plugins/index.js"
    },
    "./prosemirror/editor.css": "./dist/prosemirror/editor.css",
    "./docx": {
      "types": "./dist/docx/index.d.ts",
      "import": "./dist/docx/index.mjs",
      "require": "./dist/docx/index.js"
    },
    "./docx/serializer": {
      "types": "./dist/docx/serializer/index.d.ts",
      "import": "./dist/docx/serializer/index.mjs",
      "require": "./dist/docx/serializer/index.js"
